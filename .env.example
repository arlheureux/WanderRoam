# WanderRoam Environment Configuration
# Copy this file to .env and adjust values for your setup
# Generate secrets with: openssl rand -hex 32

# =============================================================================
# DATABASE
# =============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wanderroam
DB_USER=wanderroam
DB_PASSWORD=<set-secure-password>

# =============================================================================
# SERVER
# =============================================================================
PORT=5000
TZ=Europe/Paris

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET=<set-secure-secret>

# =============================================================================
# CORS
# =============================================================================
# Frontend origin for CORS (default: Docker service name)
CORS_ORIGIN=http://frontend:3000

# =============================================================================
# REGISTRATION
# =============================================================================
# Set to 'false' to disable new user registration
ENABLE_REGISTRATION=true

# =============================================================================
# UPLOADS
# =============================================================================
UPLOAD_DIR=/app/uploads
